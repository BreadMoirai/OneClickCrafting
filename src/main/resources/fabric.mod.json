{
  "schemaVersion": 1,
  "id": "one-click-crafting",
  "version": "${version}",
  "name": "One Click Crafting",
  "description": "Craft faster with the recipe book using less clicks",
  "authors": [
    "BreadMoirai"
  ],
  "contact": {
    "homepage": "https://github.com/BreadMoirai/OneClickCrafting",
    "issues": "https://github.com/BreadMoirai/OneClickCrafting/issues",
    "sources": "https://github.com/BreadMoirai/OneClickCrafting"
  },
  "license": "MIT",
  "icon": "assets/oneclickcrafting/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.github.breadmoirai.oneclickcrafting.client.OneClickCraftingClient"
    ],
    "modmenu": [
      "com.github.breadmoirai.oneclickcrafting.config.modmenu.OneClickCraftingModMenuEntry"
    ]
  },
  "mixins": [
    "one-click-crafting.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.7",
    "fabric-key-binding-api-v1": "*"
  },
  "recommends": {
    "modmenu": ">=17.0.0",
    "yacl": ">=3.8.1",
    "minecraft": ">=1.21.11"
  },
  "accessWidener": "oneclickcrafting.accesswidener",
  "custom": {
    "mc-publish": {
      "modrinth": "iswuGKgg",
      "dependencies": [
        "fabric-api(required)",
        "modmenu(optional)"
      ]
    }
  }
}
